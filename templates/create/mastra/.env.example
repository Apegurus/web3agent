# Model provider for the Mastra agent
# Defaults to openai/gpt-5.4 in the starter
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MASTRA_MODEL=openai/gpt-5.4

# web3agent runtime safety
CONFIRM_WRITES=true
# CONFIRM_TTL_MINUTES=30

# Optional runtime integrations
# RPC_URL=
# ETHERSCAN_API_KEY=
# LIFI_API_KEY=

# Live lifecycle example inputs
RUN_LIVE_FLOW=0
# FLOW_ACCOUNT=
# FLOW_FROM_CHAIN_ID=1
# FLOW_TO_CHAIN_ID=8453
# FLOW_FROM_TOKEN=0x0000000000000000000000000000000000000000
# FLOW_TO_TOKEN=0x0000000000000000000000000000000000000000
# FLOW_FROM_AMOUNT=1000000000000000000
