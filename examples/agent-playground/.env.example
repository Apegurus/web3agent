# ── LLM Provider ──────────────────────────────────────────────
# "anthropic" (default), "openai", or "kimi"
AI_PROVIDER=anthropic
# Override default model (e.g. claude-opus-4-6, gpt-5.4, kimi-for-coding)
# AI_MODEL=

# Provider API keys (set the one matching your provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
KIMI_API_KEY=

# ── Wallet ────────────────────────────────────────────────────
# WARNING: Never paste a real private key here — use a throwaway dev wallet only
# PRIVATE_KEY=
# MNEMONIC=
# WALLET_ACCOUNT_INDEX=0
# WALLET_ADDRESS_INDEX=0

# ── Chain & RPC ───────────────────────────────────────────────
# Default chain (defaults to Base 8453)
# CHAIN_ID=8453
# Default RPC URL override
# RPC_URL=
# Per-chain RPC overrides (e.g. RPC_URL_1=https://... for Ethereum mainnet)
# RPC_URL_1=
# RPC_URL_59144=

# ── API Keys (optional — enable additional tools/features) ────
# Etherscan: enables contract ABI lookups and explorer tools
# ETHERSCAN_API_KEY=
# LI.FI: cross-chain bridge/swap aggregator
# LIFI_API_KEY=
# 0x: DEX aggregation
# ZEROX_API_KEY=
# CoinGecko: token price lookups (free tier works without key)
# COINGECKO_API_KEY=

# ── Treasury Policy (optional — spending limits) ──────────────
# POLICY_ENABLED=true
# POLICY_MAX_SINGLE_TX_USD=100
# POLICY_MAX_HOURLY_USD=500
# POLICY_MAX_DAILY_USD=2000
# POLICY_MIN_RESERVE_USD=50
# POLICY_MAX_X402_USD=5

# ── Write Confirmation ────────────────────────────────────────
# CONFIRM_WRITES=true
# CONFIRM_TTL_MINUTES=30
